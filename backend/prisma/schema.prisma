// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANUFACTURER
  RETAILER
  USER
}

enum ProductLifecycleStatus {
  CREATED
  SHIPPED
  VERIFIED
  SOLD
}

model User {
  id        Int      @id @default(autoincrement())
  username  String?
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  boxes    Box[]

  @@index([role])
  @@index([username])
}

model Box {
  id             Int      @id @default(autoincrement())
  boxId          String
  manufacturerId Int
  batchId        String
  shippingAddress String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer User @relation(fields: [manufacturerId], references: [id])
  products     Product[]

  @@unique([manufacturerId, boxId])
  @@index([manufacturerId, batchId])
  @@index([boxId])
  @@index([batchId])
}

model Product {
  id             Int                    @id @default(autoincrement())
  productId      String
  manufacturerId Int
  boxId          Int
  batchId        String
  nfcSecret      String
  lifecycle      ProductLifecycleStatus @default(CREATED)
  shipped        Boolean                @default(false)
  verified       Boolean                @default(false)
  sold           Boolean                @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer User @relation(fields: [manufacturerId], references: [id])
  box          Box  @relation(fields: [boxId], references: [id], onDelete: Restrict)

  @@unique([manufacturerId, productId])
  @@index([productId])
  @@index([manufacturerId, boxId])
  @@index([manufacturerId, batchId])
  @@index([manufacturerId, lifecycle])
  @@index([manufacturerId, shipped, verified, sold])
}
